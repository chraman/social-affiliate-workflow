{
  "name": "myntra-whatsapp-bot",
  "version": "1.0.0",
  "description": "WhatsApp bot that scrapes Myntra product details and sends them back with affiliate links",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "scrape-test": "node src/scraper-test.js",
    "clear-wa": "rmdir /s /q .wwebjs_auth",
    "start-server": "node src/server.js",
    "dev-server": "nodemon src/server.js",
    "start-workers": "pm2 start src/ig-worker.js --name ig-worker && pm2 start src/ig-webhook.js --name ig-webhook && pm2 start src/videoWorker.js --name videoWorker",
    "stop-workers": "pm2 stop ig-worker && pm2 stop ig-webhook && pm2 stop videoWorker",
    "log-ig-worker": "pm2 logs ig-worker",
    "log-ig-webhook": "pm2 logs ig-webhook",
    "log-videoWorker": "pm2 logs videoWorker"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "playwright": "^1.44.0",
    "playwright-extra": "^4.3.6",
    "pm2": "^7.0.3",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.35.2",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
